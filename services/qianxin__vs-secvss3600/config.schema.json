{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "restBaseUrl": {
      "type": "string",
      "description": "SecVSS 3600 设备 HTTPS 基础 URL，例如 https://172.18.0.33"
    },
    "baseUrl": {
      "type": "string",
      "description": "restBaseUrl 的别名"
    },
    "endpoint": {
      "type": "string",
      "description": "restBaseUrl 的别名"
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1,
      "default": 10000,
      "description": "HTTP 请求超时毫秒数"
    },
    "tlsInsecureSkipVerify": {
      "type": "boolean",
      "default": false,
      "description": "是否跳过 TLS 证书校验（设备使用自签证书时设为 true）"
    }
  }
}
