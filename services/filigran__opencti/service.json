{
  "schema": "chaitin.octobus.service.v1",
  "name": "opencti",
  "displayName": "OpenCTI Threat Intelligence Platform",
  "description": "OctoBus package for OpenCTI threat intelligence platform: indicator, observable, and report search and creation via GraphQL API.",
  "runtime": {
    "mode": "long-running"
  },
  "proto": {
    "roots": [
      "proto"
    ],
    "files": [
      "proto/opencti.proto"
    ]
  },
  "configSchema": "config.schema.json",
  "secretSchema": "secret.schema.json",
  "sdk": {
    "cli": {
      "commands": {
        "Filigran_OPENCTI.Filigran_OPENCTI/SearchIndicators": {
          "name": "search-indicators",
          "description": "Search OpenCTI threat indicators."
        },
        "Filigran_OPENCTI.Filigran_OPENCTI/SearchObservables": {
          "name": "search-observables",
          "description": "Search OpenCTI cyber observables."
        },
        "Filigran_OPENCTI.Filigran_OPENCTI/SearchReports": {
          "name": "search-reports",
          "description": "Search OpenCTI threat reports."
        },
        "Filigran_OPENCTI.Filigran_OPENCTI/CreateIndicator": {
          "name": "create-indicator",
          "description": "Create an OpenCTI threat indicator."
        },
        "Filigran_OPENCTI.Filigran_OPENCTI/CreateObservable": {
          "name": "create-observable",
          "description": "Create an OpenCTI cyber observable."
        },
        "Filigran_OPENCTI.Filigran_OPENCTI/CreateReport": {
          "name": "create-report",
          "description": "Create an OpenCTI threat report."
        }
      }
    }
  }
}
