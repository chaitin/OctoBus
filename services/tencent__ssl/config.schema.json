{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "region": {
      "type": "string",
      "description": "Tencent Cloud region (SSL API uses ap-guangzhou by default)."
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1,
      "default": 10000,
      "description": "HTTP timeout in milliseconds."
    }
  }
}
