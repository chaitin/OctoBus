{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "endpoint": {
      "type": "string",
      "default": "https://ddoscloud-global.ctapi.ctyun.cn",
      "description": "Optional CTYun DDoS Cloud endpoint override."
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1,
      "default": 5000,
      "description": "HTTP timeout in milliseconds."
    },
    "headers": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Optional additional HTTP headers. EOP signing headers are set by the service."
    }
  }
}
