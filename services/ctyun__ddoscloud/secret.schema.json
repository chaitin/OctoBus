{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "accessKeyId": {
      "type": "string",
      "description": "CTYun CDN+ IAM AccessKey ID."
    },
    "access_key_id": {
      "type": "string",
      "description": "Alias for accessKeyId."
    },
    "ak": {
      "type": "string",
      "description": "Alias for accessKeyId."
    },
    "secretAccessKey": {
      "type": "string",
      "description": "CTYun CDN+ IAM Secret Access Key."
    },
    "secret_access_key": {
      "type": "string",
      "description": "Alias for secretAccessKey."
    },
    "sk": {
      "type": "string",
      "description": "Alias for secretAccessKey."
    }
  }
}
