{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "appId": {
      "type": "string",
      "description": "Tencent TIX AppID. It is associated with the AppKey authorization and is not sent in TIX API request bodies."
    },
    "app_id": {
      "type": "string",
      "description": "Alias for appId."
    },
    "appKey": {
      "type": "string",
      "description": "Tencent TIX API AppKey."
    },
    "app_key": {
      "type": "string",
      "description": "Alias for appKey."
    },
    "c_appkey": {
      "type": "string",
      "description": "Alias matching Tencent TIX request field name."
    }
  }
}
