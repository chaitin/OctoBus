{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "token": { "type": "string", "description": "CloudLock web session token (sent as the 'token' header). Time-limited; refresh when expired." },
    "sessionToken": { "type": "string", "description": "Alias for token." },
    "session_token": { "type": "string", "description": "Alias for token." }
  }
}
