{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "dependency_track_api_key": {
      "type": "string",
      "description": "Dependency-Track API key. Sent as X-Api-Key."
    },
    "apiKey": {
      "type": "string",
      "description": "Alias for dependency_track_api_key."
    },
    "xApiKey": {
      "type": "string",
      "description": "Alias for dependency_track_api_key."
    }
  }
}
