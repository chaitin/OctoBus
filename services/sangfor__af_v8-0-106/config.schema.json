{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "baseUrl"
  ],
  "properties": {
    "baseUrl": {
      "type": "string",
      "minLength": 1
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1,
      "default": 10000
    },
    "allowInsecureHttp": {
      "type": "boolean",
      "default": false
    },
    "skipTlsVerify": {
      "type": "boolean",
      "default": false
    },
    "headers": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
