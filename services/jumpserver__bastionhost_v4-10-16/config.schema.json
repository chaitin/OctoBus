{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "endpoint": {
      "type": "string",
      "description": "JumpServer base URL, for example https://jumpserver.example.com."
    },
    "apiPrefix": {
      "type": "string",
      "default": "/api/v1",
      "description": "JumpServer REST API prefix. Most deployments use /api/v1."
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1,
      "default": 10000,
      "description": "HTTP request timeout in milliseconds."
    },
    "rejectUnauthorized": {
      "type": "boolean",
      "default": true,
      "description": "Whether to verify upstream TLS certificates."
    },
    "headers": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Optional extra HTTP headers."
    }
  },
  "required": [
    "endpoint"
  ]
}
