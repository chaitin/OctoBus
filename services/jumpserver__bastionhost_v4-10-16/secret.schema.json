{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "token": {
      "type": "string",
      "description": "JumpServer API token. Sent as Authorization: Token <token> by default."
    },
    "authorization": {
      "type": "string",
      "description": "Full Authorization header value. Overrides token when configured."
    }
  },
  "anyOf": [
    {
      "required": [
        "token"
      ]
    },
    {
      "required": [
        "authorization"
      ]
    },
    {
      "required": [
        "username",
        "password"
      ]
    }
  ]
}
