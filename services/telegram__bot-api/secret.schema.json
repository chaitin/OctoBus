{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "bot_token": {
      "type": "string",
      "description": "Telegram Bot Token issued by BotFather."
    },
    "botToken": {
      "type": "string",
      "description": "Alias for bot_token."
    },
    "token": {
      "type": "string",
      "description": "Legacy alias for bot_token."
    }
  }
}
