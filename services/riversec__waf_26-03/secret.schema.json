{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "tokenId": {
      "type": "string",
      "description": "TokenID from the Botgate system API page, for example api_admin."
    },
    "token_id": {
      "type": "string",
      "description": "Alias for tokenId."
    },
    "tokenValue": {
      "type": "string",
      "description": "TokenValue used as the HMAC-SHA256 signing key."
    },
    "token_value": {
      "type": "string",
      "description": "Alias for tokenValue."
    },
    "token": {
      "type": "string",
      "description": "Alias for tokenValue."
    }
  }
}
