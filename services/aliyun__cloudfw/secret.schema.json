{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "accessKeyId",
    "accessKeySecret"
  ],
  "properties": {
    "accessKeyId": {
      "type": "string",
      "minLength": 1,
      "description": "Alibaba Cloud AccessKey ID."
    },
    "accessKeySecret": {
      "type": "string",
      "minLength": 1,
      "description": "Alibaba Cloud AccessKey secret."
    },
    "securityToken": {
      "type": "string",
      "description": "Optional Alibaba Cloud STS security token."
    }
  }
}
