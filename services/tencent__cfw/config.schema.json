{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "region": {
      "type": "string",
      "description": "Tencent Cloud region, e.g. ap-guangzhou, ap-shanghai."
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1,
      "default": 10000,
      "description": "HTTP timeout in milliseconds."
    },
    "skipTlsVerify": {
      "type": "boolean",
      "default": false,
      "description": "Skip TLS certificate verification."
    },
    "tlsInsecureSkipVerify": {
      "type": "boolean",
      "default": false,
      "description": "Alias for skipTlsVerify."
    },
    "insecureSkipVerify": {
      "type": "boolean",
      "default": false,
      "description": "Alias for skipTlsVerify."
    }
  }
}
