{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "password": {
      "type": "string",
      "description": "Optional raw IPSV6079 login password. The service hashes it with SHA256 before login."
    },
    "passwordSha256": {
      "type": "string",
      "description": "Optional pre-hashed SHA256 password."
    },
    "password_sha256": {
      "type": "string",
      "description": "Alias for passwordSha256."
    },
    "token": {
      "type": "string",
      "description": "Optional pre-issued IPSV6079 authorization token."
    }
  }
}
