{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "password": {
      "type": "string",
      "description": "Optional default TAR login password."
    },
    "token": {
      "type": "string",
      "description": "Optional pre-issued TAR token."
    },
    "cookie": {
      "type": "string",
      "description": "Optional pre-issued TAR cookie header."
    }
  }
}
