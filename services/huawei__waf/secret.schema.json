{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "access_key": {
      "type": "string",
      "description": "Huawei Cloud Access Key (AK)."
    },
    "secret_key": {
      "type": "string",
      "description": "Huawei Cloud Secret Key (SK)."
    },
    "ak": {
      "type": "string",
      "description": "Alias for access_key."
    },
    "sk": {
      "type": "string",
      "description": "Alias for secret_key."
    }
  }
}
