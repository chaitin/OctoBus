{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "username",
    "apiSecret"
  ],
  "properties": {
    "username": {
      "type": "string",
      "minLength": 1,
      "description": "Huayulab NGAF API username."
    },
    "apiSecret": {
      "type": "string",
      "minLength": 1,
      "description": "Huayulab NGAF API secret used to compute md5(md5(apiSecret) + \"-api-!*195\")."
    }
  }
}

