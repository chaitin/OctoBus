{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "tdp_authentication": {
      "type": "string",
      "description": "ThreatBook TDP web console session token, sent as the tdp-authentication header."
    },
    "tdpAuthentication": {
      "type": "string",
      "description": "Alias for tdp_authentication."
    },
    "token": {
      "type": "string",
      "description": "Alias for tdp_authentication."
    }
  }
}
