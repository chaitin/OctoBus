{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "ctyun_gateway": {
      "type": "string",
      "description": "天翼云 CTAPI 网关地址，默认 accessone-global.ctapi.ctyun.cn。",
      "default": "accessone-global.ctapi.ctyun.cn"
    },
    "gateway": {
      "type": "string",
      "description": "Alias for ctyun_gateway."
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1,
      "default": 10000,
      "description": "HTTP timeout in milliseconds."
    },
    "skipTlsVerify": {
      "type": "boolean",
      "default": false,
      "description": "Skip TLS certificate verification for private deployments."
    },
    "tlsInsecureSkipVerify": {
      "type": "boolean",
      "default": false,
      "description": "Legacy alias for skipTlsVerify."
    },
    "insecureSkipVerify": {
      "type": "boolean",
      "default": false,
      "description": "Legacy alias for skipTlsVerify."
    }
  }
}
