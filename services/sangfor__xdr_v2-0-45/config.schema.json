{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "baseUrl"
  ],
  "properties": {
    "baseUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https?://",
      "description": "Sangfor XDR base URL, for example https://xdr.example.com."
    },
    "timeoutMs": {
      "type": "integer",
      "minimum": 1,
      "maximum": 300000,
      "default": 15000
    },
    "skipTlsVerify": {
      "type": "boolean",
      "default": false
    },
    "headers": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "default": {}
    }
  }
}
