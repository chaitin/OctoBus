{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "authCode": {
      "type": "string",
      "minLength": 1,
      "description": "Sangfor linkage authCode."
    },
    "accessKey": {
      "type": "string",
      "minLength": 1
    },
    "secretKey": {
      "type": "string",
      "minLength": 1
    }
  },
  "oneOf": [
    {
      "required": [
        "authCode"
      ],
      "not": {
        "anyOf": [
          {
            "required": [
              "accessKey"
            ]
          },
          {
            "required": [
              "secretKey"
            ]
          }
        ]
      }
    },
    {
      "required": [
        "accessKey",
        "secretKey"
      ],
      "not": {
        "required": [
          "authCode"
        ]
      }
    }
  ]
}
